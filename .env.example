# === 存储层 ===
PG_HOST=localhost
PG_PORT=5432
PG_DB=stock_hawk
PG_USER=stock_hawk
PG_PASSWORD=stock_hawk_dev

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=stock_hawk_dev

REDIS_URL=redis://localhost:6379/0

# === 数据源 API Keys ===
# Tushare Token（财报/披露日/估值采集必需；未配置则财报信号显式阻断）
