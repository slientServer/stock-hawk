# === LLM API Keys ===
# 自定义 OpenAI 兼容端点（优先级最高）
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# 至少配置一个LLM服务
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=

# === 通知 ===
FEISHU_WEBHOOK_URL=

# === 系统配置 ===
LOG_LEVEL=INFO
DATA_DIR=./data
